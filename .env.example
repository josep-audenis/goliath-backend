# --- LLM (OpenAI-compatible). Pick one provider. App runs deterministically if none set. ---
LLM_PROVIDER=groq           # groq | openai | hf
AGENT_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=

# --- Cala data layer ---
CALA_API_KEY=
USE_CALA_MOCK=true           # true -> subagents return credible mock data
CALA_MCP_API_KEY=            # enables open-ended knowledge_search inside agents

# --- ElevenLabs TTS (backend-side; optional) ---
ELEVENLABS_API_KEY=
